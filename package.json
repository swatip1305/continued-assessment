{
  "name": "api-automation",
  "version": "1.0.0",
  "description": "Create test suite to automate the api ",
  "license": "ISC",
  "author": "Swati Patel",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "cypress run"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.14.1",
    "esbuild": "^0.28.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/**/*.{js,ts}",
      "cypress/support/step_definitions/**/*.{js,ts}"
    ],
    "json": {
      "enabled": true,
      "output": "cypress/reports/cucumber-report.json"
    }
  }
}
